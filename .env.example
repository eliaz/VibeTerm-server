# VibeTerm server-side config.
# Copy to `.env.local` and edit for your machine:
#   cp .env.example .env.local

VIBETERM_UI_HOST=0.0.0.0
VIBETERM_UI_PORT=3457
VIBETERM_UI_FILE=server/vibeterm-ui.json

# HTTPS is on by default. If the cert/key files are missing, the server creates
# local self-signed certs in `.certs/`. Set VIBETERM_TLS=0 for plain HTTP.
VIBETERM_TLS=1
VIBETERM_TLS_CERT=.certs/vibeterm.cert.pem
VIBETERM_TLS_KEY=.certs/vibeterm.key.pem
VIBETERM_TLS_DAYS=3650

# Hostname or LAN IP that the phone can reach. Leave empty to use the machine hostname.
VIBETERM_PUBLIC_HOST=
# Optional full public base URL, useful behind Caddy, nginx, or a tunnel.
VIBETERM_PUBLIC_URL=

# Set this to the same token configured in the Even Hub app.
VIBETERM_PROJECT_TOKEN=change-me

# Project folders and tmux session names.
VIBETERM_PROJECTS_DIR=.projects
VIBETERM_TMUX_SESSION_PREFIX=vibeterm-
VIBETERM_SESSION_NAMESPACE=even-glasses

# Shell row launched inside each project tmux session after `cd <project-dir>`.
# Put every project bootstrap command here.
VIBETERM_TMUX_EXEC_ROW='git init >/dev/null 2>&1 || true; codex --yolo --enable use_legacy_landlock'

# Keep the tmux session alive if the exec row exits during update/crash.
VIBETERM_TMUX_RESTART_EXEC=1
VIBETERM_TMUX_RESTART_DELAY=2

# Terminal snapshot/polling tuning.
VIBETERM_TMUX_HISTORY_LINES=240
VIBETERM_TMUX_BOOT_DELAY_MS=1200

# Optional browser export for each tmux project via ttyd.
VIBETERM_TMUX_AUTO_EXPORT=1
VIBETERM_TMUX_EXPORT_BASE_PORT=7681
VIBETERM_TMUX_EXPORT_DURATION=24h
VIBETERM_TMUX_EXPORT_TLS=1

# Speech-to-text for G2 microphone input.
# Put real keys only in `.env.local`.
OPENAI_API_KEY=
VIBETERM_STT_OPENAI_MODEL=gpt-4o-mini-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1
VIBETERM_STT_TIMEOUT_MS=30000
VIBETERM_STT_MAX_BYTES=10485760
VIBETERM_STT_LANGUAGE=
VIBETERM_STT_PROMPT=

# Or use a local command instead of OpenAI. The command should print transcript
# text to stdout. `{file}` is replaced with the temporary WAV path.
# VIBETERM_STT_COMMAND='whisper-cli -m /path/to/ggml-base.en.bin -f {file} -nt -otxt'

# Eventerm server-side config.
# Copy to `.env.local` and edit for your machine:
#   cp .env.example .env.local

ETERM_UI_HOST=0.0.0.0
ETERM_UI_PORT=3457
ETERM_UI_FILE=server/eterm-ui.json

# Set this to the same token configured in the Even Hub app.
ETERM_PROJECT_TOKEN=change-me

# Project folders and tmux session names.
ETERM_PROJECTS_DIR=.projects
ETERM_TMUX_SESSION_PREFIX=eventerm-

# Shell row launched inside each project tmux session after `cd <project-dir>`.
# Put every project bootstrap command here.
ETERM_TMUX_EXEC_ROW='git init >/dev/null 2>&1 || true; codex --yolo --enable use_legacy_landlock'

# Keep the tmux session alive if the exec row exits during update/crash.
ETERM_TMUX_RESTART_EXEC=1
ETERM_TMUX_RESTART_DELAY=2

# Terminal snapshot/polling tuning.
ETERM_TMUX_HISTORY_LINES=240
ETERM_TMUX_BOOT_DELAY_MS=1200

# Optional browser export for each tmux project via ttyd.
ETERM_TMUX_AUTO_EXPORT=1
ETERM_TMUX_EXPORT_BASE_PORT=7681
ETERM_TMUX_EXPORT_DURATION=6h

# Speech-to-text for G2 microphone input.
# Put real keys only in `.env.local`.
OPENAI_API_KEY=
ETERM_STT_OPENAI_MODEL=gpt-4o-mini-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1
ETERM_STT_TIMEOUT_MS=30000
ETERM_STT_MAX_BYTES=10485760
ETERM_STT_LANGUAGE=
ETERM_STT_PROMPT=

# Or use a local command instead of OpenAI. The command should print transcript
# text to stdout. `{file}` is replaced with the temporary WAV path.
# ETERM_STT_COMMAND='whisper-cli -m /path/to/ggml-base.en.bin -f {file} -nt -otxt'
